FROM jenkins/inbound-agent:latest

USER root

RUN apt-get update && apt-get install -y ca-certificates git curl wget && \
    echo "deb [trusted=yes] https://download.docker.com/linux/debian $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
    > /etc/apt/sources.list.d/docker.list && \
    apt-get update && apt-get install -y docker-ce-cli && \
    rm -rf /var/lib/apt/lists/* 

RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm

RUN groupadd -g 2001 docker && usermod -aG docker jenkins

RUN groupadd -g 2000 jenkins-shared && usermod -aG jenkins-shared jenkins

RUN apt-get update && apt-get install -y python3 python3-pip && \
    pip3 install pytest schemathesis --break-system-packages && \
    rm -rf /var/lib/apt/lists/*

USER jenkins

